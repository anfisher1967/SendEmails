# Azure / Sentinel Configuration
AZURE_TENANT_ID=your-tenant-id-here
AZURE_SUBSCRIPTION_ID=your-subscription-id-here
SENTINEL_WORKSPACE_ID=your-workspace-id-here
SENTINEL_RESOURCE_GROUP=your-resource-group-name

# API Authentication (Service Principal or App Registration)
AZURE_CLIENT_ID=your-app-registration-id-here
AZURE_CLIENT_SECRET=your-app-registration-secret-here

# Defender XDR Configuration
DEFENDER_TENANT_ID=your-tenant-id-here

# Agent Configuration
AGENT_LOG_LEVEL=INFO
AGENT_MODE=advisory

# Optional: Microsoft Graph Configuration
GRAPH_API_VERSION=v1.0
